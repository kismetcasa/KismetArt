# Keep the build context small and prevent stale artifacts or secrets
# from being uploaded to the Docker daemon.

# Git + editor state
.git
.gitignore
.github
.vscode
.idea

# Build outputs — regenerated by the builder stage.
node_modules
.next
out

# postinstall regenerates this from node_modules at every fresh install,
# and the source-tree copy is gitignored anyway. Excluding it from the
# build context guarantees the builder stage uses the freshly-installed
# version, not a stale local copy from a dev workstation.
public/ffmpeg-core

# Local + secret env files. Only the template (.env.example) ships.
.env
.env.local
.env.*.local

# OS / editor cruft
.DS_Store
*.swp
*.swo

# Coverage / logs / typegen
coverage
*.log
*.tsbuildinfo
next-env.d.ts

# Pre-migration leftover
.vercel
