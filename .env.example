# Canonical origin for the deployment. The single source of truth for:
#   - metadataBase (resolves all relative og:image URLs)
#   - the Farcaster Mini App manifest's homeUrl
#   - per-page Farcaster embed action.url
#   - notification targetUrl host (must match exactly or tokens are invalidated)
# Pick ONE host. The Farcaster account association signature is bound to
# the host string; switching requires a domain migration.
NEXT_PUBLIC_SITE_URL=https://kismet.art

# WalletConnect Cloud project ID — required for WalletConnect wallet option
# Get a free project ID at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Base mainnet RPC URL — strongly recommended for production. Falls back to
# Base's public endpoint (mainnet.base.org) when unset, which is rate-limited
# and surfaces as "over rate limit" errors during on-chain reads (e.g. the
# permissions check in the airdrop authorize flow). Use Alchemy, Infura,
# QuickNode, or any provider with adequate quota.
# Example: https://base-mainnet.g.alchemy.com/v2/<your-key>
NEXT_PUBLIC_BASE_RPC_URL=

# Optional server-only Base RPC URL. When set, server-side reads (lib/rpc.ts —
# collect verification, on-chain permission checks, the readiness probe) use
# this in preference to NEXT_PUBLIC_BASE_RPC_URL, so the paid key driving
# server reads isn't the one inlined into the client bundle (NEXT_PUBLIC_
# values ship to every browser). Leave unset to share the public key above.
# The browser wallet path still uses NEXT_PUBLIC_BASE_RPC_URL — restrict that
# key by domain/origin allowlist at the provider.
BASE_RPC_URL=

# Ethereum mainnet RPC URL — used for client-side ENS resolution
# (useEnsName) and as the fallback for server-side ENS resolution in
# /api/profile/[address]. Falls back to viem's public endpoint when unset,
# which is rate-limited under load.
NEXT_PUBLIC_MAINNET_RPC_URL=

# Optional server-only Ethereum mainnet RPC URL. When set, server-side ENS
# resolution in /api/profile/[address] uses this in preference to
# NEXT_PUBLIC_MAINNET_RPC_URL — useful if you want a higher-quota key on
# the server without exposing it to clients. Leave unset to share the
# public mainnet key above.
MAINNET_RPC_URL=

# inprocess API key — required for Collect (not needed for Mint)
# Get yours at: https://inprocess.world/manage/api-keys
INPROCESS_API_KEY=art_sk_...

# The collection address for this client's feed
# All mints go to this collection; the Discover feed filters by it.
# Set to your deployed collection address on Base.
# Test value: 0x5e9e0BB95F6b8326005DB93AC2cf6F4F0C66578F
NEXT_PUBLIC_PLATFORM_COLLECTION=0x5e9e0BB95F6b8326005DB93AC2cf6F4F0C66578F

# Arweave signing proxy — required for media uploads
# Generate a wallet at: https://arweave.app, export the JWK JSON, then:
#   base64 -i wallet.json | tr -d '\n'          → paste as ARWEAVE_JWK (server-only)
#   cat wallet.json | jq -r '.n'                → paste as NEXT_PUBLIC_ARWEAVE_N (RSA modulus, public)
# The private key never leaves the server; only a 48-byte hash crosses the network.
#
# SPEND BACKSTOP (operational): /api/sign signs media data items that stream
# client → Turbo directly, so the server never sees the bytes and CANNOT meter
# them. Per-identity abuse is bounded by a daily signing-count quota
# (lib/userQuota.ts, 'sign-calls'), but the only hard ceiling on catastrophic
# drain is the funding source itself. Do NOT park a large Turbo balance on this
# wallet (or on the NEXT_PUBLIC_ARWEAVE_PAID_BY funder below). Keep it topped to
# a bounded float and alert on the balance:
#   https://payment.ardrive.io/v1/balance/arweave/<this-wallet-address>
ARWEAVE_JWK=
NEXT_PUBLIC_ARWEAVE_N=

# Optional: comma-separated list of addresses whose Turbo credits this wallet
# is approved to spend. Use when this wallet has zero direct credits but has
# received approvals (e.g. from a shared funding wallet). The paying address
# is public (it's recorded on-chain in the approval), so NEXT_PUBLIC_ is fine.
# Verify approvals at:
#   https://payment.ardrive.io/v1/balance/arweave/<your-wallet-address>
# Example: NEXT_PUBLIC_ARWEAVE_PAID_BY=0x3D140B892437dD7857701098415deB2daaE03A40
NEXT_PUBLIC_ARWEAVE_PAID_BY=

# Optional: referral address to receive create referral rewards
NEXT_PUBLIC_CREATE_REFERRAL=

# Admin wallet — grants curation rights on the Featured tab (server-only, never sent to browser)
ADMIN_ADDRESS=

# Operator smart wallet — the inprocess CDP smart wallet that submits userOps
# on behalf of the platform identity (e.g. Kismet Casa) when minting curated
# content into NEXT_PUBLIC_PLATFORM_COLLECTION. Resolved once via
# https://api.inprocess.world/api/smartwallet?artist_wallet=<eoa> and pinned
# here so the startup healthcheck (lib/healthcheck.ts) can log a loud
# diagnostic if this wallet ever loses ADMIN on the platform collection.
# Leave unset to skip the check (e.g. in dev / forks). Server-only; never
# sent to the browser.
OPERATOR_SMART_WALLET=

# Public mirror of OPERATOR_SMART_WALLET — must hold the SAME address.
# Required for the browser-side deploy flow: CreateCollectionForm bakes
# this wallet into the new collection's setupActions so it gets ADMIN
# alongside the artist's smart wallet at deploy time. Without this grant,
# downstream airdrops (which inprocess routes through the operator wallet
# under our shared API key) revert with "admin permission" upstream
# even when the artist's own smart wallet has ADMIN. The boot healthcheck
# implicitly verifies they match by reading this same wallet's perms on
# PLATFORM_COLLECTION; mismatched env vars surface as a startup failure.
NEXT_PUBLIC_OPERATOR_SMART_WALLET=

# ──────────────────────────────────────────────────────────────────────────
# Farcaster Mini App
# ──────────────────────────────────────────────────────────────────────────
# Kismet renders as a Mini App when opened inside a Farcaster host (the
# Farcaster app, Base App, any third-party Farcaster client). Desktop and
# mobile web are unaffected — the SDK is dynamically loaded only when an
# iframe / RN WebView is detected.
# See providers/FarcasterProvider.tsx.
#
# Domain ownership is proved by the static manifest at
# public/.well-known/farcaster.json. The accountAssociation block in that
# file was signed once via Farcaster's Mini App Manifest tool
# (https://farcaster.xyz/~/developers/new) — kismet.art → FID 527681
# (custody type). To rotate or move domains, re-sign and overwrite the
# accountAssociation in the static file. No env vars needed.

# Brand asset URLs — all optional. Defaults to /icon.png, /splash.png,
# /embed-default.png served from public/. Override with absolute URLs
# (e.g. Arweave gateway) to avoid checking PNGs into the repo.
# All URLs validated against @farcaster/miniapp-core's secureUrlSchema:
# must be https, <=1024 chars, no IP/localhost hostnames.
#   iconUrl:         1024x1024 PNG, NO alpha channel (publishing spec).
#   splashImageUrl:  exactly 200x200 PNG (publishing spec).
#   embed imageUrl:  3:2 ratio PNG, 600x400 min, 3000x2000 max, <10MB.
#                    Used by Phase 1's homepage embed in app/layout.tsx
#                    (per-page embeds for moment / collection / profile
#                    in Phase 4 use their own opengraph-image routes).
NEXT_PUBLIC_FARCASTER_ICON_URL=
NEXT_PUBLIC_FARCASTER_SPLASH_URL=
NEXT_PUBLIC_FARCASTER_EMBED_IMAGE_URL=

# Copy + theme overrides. Sensible defaults are baked in so these are all
# optional. APP_NAME max ~30 chars, BUTTON_TITLE max 32 chars (truncated).
NEXT_PUBLIC_FARCASTER_APP_NAME=
NEXT_PUBLIC_FARCASTER_BUTTON_TITLE=
NEXT_PUBLIC_FARCASTER_DESCRIPTION=
NEXT_PUBLIC_FARCASTER_SUBTITLE=
NEXT_PUBLIC_FARCASTER_TAGLINE=
NEXT_PUBLIC_FARCASTER_CATEGORY=
NEXT_PUBLIC_FARCASTER_SPLASH_BG=

# Farcaster Hub URL for webhook signature verification. Optional;
# defaults to https://hub.farcaster.xyz (Farcaster team's public hub).
# Override with a self-hosted hub or a Neynar endpoint
# (https://hub-api.neynar.com — pair with API-key headers via a small
# wrapper in app/api/farcaster/webhook/route.ts if you switch).
# Used by app/api/farcaster/webhook to resolve the FID's app keys on
# every incoming miniapp_added / notifications_enabled event.
FARCASTER_HUB_URL=

# ──────────────────────────────────────────────────────────────────────────
# Pass-transfer webhook (Alchemy)
# ──────────────────────────────────────────────────────────────────────────
# Required when the token gate is enabled in /admin/gate. Alchemy posts
# every Transfer event of the configured Pass collection contract to
# /api/webhooks/pass-transfer, where processTransfer enforces the
# provenance gate per the "valid pass" definition (acquired through
# mint / airdrop / Kismet secondary, with every link on-platform):
#
#   ON-PLATFORM acquisition (mint via /api/collect, airdrop via
#   /api/airdrop/notify, secondary sale via /api/listings/[id] filled)
#     → buyer credited via creditValidityOnce. Each path proves the
#     on-chain event server-side first; listing fills also direct-
#     credit synchronously so the buyer is valid without waiting for
#     the webhook, with the webhook converging as a backstop.
#
#   OFF-PLATFORM transfer (OpenSea, direct Seaport fill, P2P send, burn)
#     → SELLER decrement runs unconditionally (revokes their validity);
#     BUYER is NOT credited; the TOKENID is permanently TAINTED. Tainted
#     tokenIds can never confer validity again, even if subsequently
#     relisted on Kismet — creditValidityOnce checks the taint flag and
#     refuses credit. hasValidPass also excludes tainted tokenIds from
#     liveTotal so a missed webhook decrement can't keep a tainted-only
#     holder valid.
#
# So the webhook is critical for:
#   - off-platform seller revocation (the from-decrement),
#   - launder-prevention (the tokenId taint flag),
#   - on-platform crediting backstop (creditValidityOnce convergence).
# Without it the gate still works for on-platform acquisitions (direct
# credit), but off-platform transfers wouldn't revoke or taint until
# the missing event was retroactively delivered.
#
# Setup:
#   1. Alchemy → Notify → Create Webhook
#   2. Type: NFT ACTIVITY — REQUIRED. Do NOT use Address Activity: it keys
#      on the from/to wallet, not the token contract, so watching the Pass
#      collection address there won't fire on collect-mints AND its payload
#      omits the top-level `contractAddress` field this handler filters on
#      (it uses rawContract.address) — every event would be silently
#      skipped with a 200. NFT Activity filters by contract and emits the
#      `contractAddress` + `erc1155Metadata` shape the handler expects.
#   3. Network: Base Mainnet
#   4. URL: https://kismet.art/api/webhooks/pass-transfer
#   5. Contract to watch: the Pass collection contract set in /admin/gate.
#      Re-edit the webhook whenever you switch collections.
#   6. Copy the "Signing Key" from the webhook page → paste below.
#
# The handler does a length-checked, timing-safe HMAC-SHA256 compare
# against the X-Alchemy-Signature header on every POST; an unset or
# wrong key returns 401 and the request is dropped with no state change.
# Without this var, only on-platform activity grants validity —
# secondary marketplace purchases of the Pass will not register.
ALCHEMY_WEBHOOK_SIGNING_KEY=
